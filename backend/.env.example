# ===========================
# Enterprise CMS — Backend
# ===========================

APP_NAME="Enterprise CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cms_db
DB_USERNAME=cms_user
DB_PASSWORD=cms_secret_2026

# --- Session ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Drivers ---
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080

# --- Mail (Mailpit for dev) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cms-enterprise.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3 / MinIO ---
AWS_ACCESS_KEY_ID=cms_minio_admin
AWS_SECRET_ACCESS_KEY=cms_minio_secret_2026
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=cms-media
AWS_URL=http://localhost:9000
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Sentry ---
SENTRY_LARAVEL_DSN=

# --- Reverb (WebSocket) ---
REVERB_APP_ID=cms-reverb
REVERB_APP_KEY=cms-reverb-key
REVERB_APP_SECRET=cms-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
